# MiniMax API key.
# This key is only read by the local backend and must never be exposed to the browser.
MINIMAX_API_KEY="yourAPIKEY"

# Optional author key used by the in-game "使用作者的KEY" button.
# Keep this unset in public builds unless the author intentionally provides a backend-only key.
TWILIGHT_AUTHOR_MINIMAX_API_KEY=""

# MiniMax text-chat model. The current NPC dialogue integration uses MiniMax-M2.5.
MINIMAX_MODEL="MiniMax-M2.5"

# MiniMax API base URL.
MINIMAX_BASE_URL="https://api.minimaxi.com"

# Request timeout in milliseconds for the local backend -> MiniMax call.
MINIMAX_TIMEOUT_MS="20000"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
