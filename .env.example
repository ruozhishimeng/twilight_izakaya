# MiniMax API key.
# This key is only read by the local backend and must never be exposed to the browser.
MINIMAX_API_KEY="yourAPIKEY"

# MiniMax text-chat model. The current NPC dialogue integration uses M2-her.
MINIMAX_MODEL="M2-her"

# MiniMax API base URL.
MINIMAX_BASE_URL="https://api.minimaxi.com"

# Request timeout in milliseconds for the local backend -> MiniMax call.
MINIMAX_TIMEOUT_MS="8000"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
